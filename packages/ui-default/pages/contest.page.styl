$highlight-button-color = #F6DF45

.page--contest_main
  .contest__list
    display: grid
    gap: rem(14px)

  .contest__title
    font-size: rem($font-size-title)
    line-height: 1.2em
    margin: 0

  .contest__date
    margin-right: rem(10px)
    white-space: nowrap
    width: rem(60px)
    border-radius: rem(12px)
    background: #f8fafc
    box-shadow: inset 0 0 0 1px #e5edf7

  .contest__info-attended
    color: $success-color

  .contest__item
    border: 1px solid #e5edf7
    border-left: rem(5px) solid transparent
    border-radius: rem(14px)
    padding: rem(14px 16px 14px 11px)
    background: linear-gradient(135deg, #fff 0%, #f8fbff 100%)
    box-shadow: 0 rem(10px) rem(26px) rgba(#0f172a, .06)
    transition: transform .18s ease, box-shadow .18s ease

    &:hover
      transform: translateY(rem(-2px))
      box-shadow: 0 rem(16px) rem(34px) rgba(#0f172a, .1)
    
    &.live
      border-left: rem(5px) solid #E98696

    &.ready
      border-left: rem(5px) solid #469DCF

    &.done
      border-left: rem(5px) solid #22c55e

  .contest__item-topline
    display: flex
    align-items: center
    justify-content: space-between
    gap: rem(12px)
    margin-bottom: rem(10px)

  .contest__status-pill
    flex: 0 0 auto
    border-radius: rem(999px)
    padding: rem(4px 10px)
    background: #eef2ff
    color: #3730a3
    font-size: rem($font-size-small)
    font-weight: 700

  .contest__item-footer
    display: flex
    align-items: center
    justify-content: space-between
    gap: rem(12px)
    margin-top: rem(11px)
    color: #64748b
    font-size: rem($font-size-small)

  .contest__enter-link
    flex: 0 0 auto
    border-radius: rem(999px)
    padding: rem(5px 12px)
    background: #2563eb
    color: #fff
    font-weight: 700

    &:hover
      color: #fff
      text-decoration: none
      background: #1d4ed8

  .section--contest
    &.live
      background: #E98696
      background-image: -webkit-radial-gradient(left top, ellipse farthest-corner, #E98696 0%, #E96B6B 100%)

    &.ready
      background: #469DCF
      background-image: -webkit-radial-gradient(left top, ellipse farthest-corner, #8ACDE6 0%, #469DCF 100%)

    .status_title
      display: inline-block
      font-size: rem($font-size-secondary)
      color: #FFF
      background: rgba(#000, 0.3)
      padding: rem(7px 10px)
      border-radius: rem(2px)

    h1
      line-height: 1.2
      font-size: rem(25px)
      margin: rem(20px 0)

    .info
      color: #FFF
      font-size: rem($font-size-secondary)

      .icon
        color: #FFEB81
        font-size: rem($font-size-icon)

      li
        display: inline-block
        margin-right: rem(10px)

    .attandance
      margin-top: rem(15px)
      font-size: rem($font-size-secondary)
      opacity: 0.8

    .detail-button
      cursor: pointer
      display: block
      text-align: center
      background: $highlight-button-color
      color: darken($highlight-button-color, 70%)
      line-height: rem(40px)
      border-radius: rem(20px)
      width: rem(150px)
      position: relative
      overflow: hidden
      transition: box-shadow .4s, background-color .4s
      transition-timing-function: ease-out-cubic

      &:after
        position: absolute
        background: #fff
        content: ""
        height: rem(100px)
        left: rem(-70px)
        top: rem(-25px)
        width: rem(50px)
        opacity: 0.2
        transform: rotate(35deg)
        transition: left 0.6s ease-out-cubic
        z-index: 1

      &:hover
        text-decoration: none
        box-shadow: 0 2px 20px rgba($highlight-button-color, 0.8)
        background: lighten($highlight-button-color, 20%)

        &:after
          left: 150%

    +mobile()
      .media, .media_body, .media__right
        display: block
        padding: 0

      .media__right .section__body
        padding-top: 0

      .detail-button
        width: auto

  +mobile()
    .contest__item-topline,
    .contest__item-footer
      display: block

    .contest__status-pill,
    .contest__enter-link
      display: inline-block
      margin-top: rem(8px)

.page--contest_detail
  .contest-detail-hero
    overflow: hidden
    border: 1px solid #dbe7f3
    border-radius: rem(18px)
    background: radial-gradient(circle at 86% 24%, rgba(#60a5fa, .18), transparent 32%), linear-gradient(135deg, #ffffff 0%, #f3f8ff 100%)
    box-shadow: 0 rem(14px) rem(36px) rgba(#0f172a, .08)

    .section__body
      position: relative
      padding: rem(28px)

  .contest-detail-hero__eyebrow
    display: flex
    flex-wrap: wrap
    gap: rem(8px)
    margin-bottom: rem(12px)

    span
      border-radius: rem(999px)
      padding: rem(4px 10px)
      background: #e0ecff
      color: #1d4ed8
      font-size: rem($font-size-small)
      font-weight: 800

  .contest-detail-hero__title
    margin: 0 0 rem(18px)
    color: #0f172a
    font-size: rem(30px)
    line-height: 1.2

  .contest-detail-hero__meta
    display: flex
    flex-wrap: wrap
    gap: rem(9px)

    > span
      border: 1px solid #dbe7f3
      border-radius: rem(12px)
      padding: rem(7px 10px)
      background: rgba(#fff, .78)
      color: #475569
      font-size: rem($font-size-small)

    .icon
      margin-right: rem(5px)
      color: #2563eb

  .contest-detail-hero__attended
    display: inline-flex
    align-items: center
    gap: rem(6px)
    margin-top: rem(16px)
    border-radius: rem(999px)
    padding: rem(7px 12px)
    background: #dcfce7
    color: #166534
    font-weight: 800

.page--contest_problemlist
  .col--status, .col--correction
    width: rem(150px)

  .col--submit-at
    width: rem(130px)
    text-align: center

  &.nojs .col--submit-at
    width: rem(160px)

  .col--score
    width: rem(80px)
    text-align: center;

  .col--problem
    border-left: 1px solid $table-border-color

  +mobile()
    .col--submit-at, .col--correction
      display: none

  +tablet()
    .col--time,
    .col--memory,
    .col--lang
      display: none

  +mobile()
    .col--time,
    .col--memory,
    .col--submit-at,
    .col--lang
      display: none
  
  .col--submit-by
    display: none

  .record_main__table
    .col--status
      width: rem(170px)

    .col--time, .col--memory, .col--lang
      width: rem(95px)
      text-align: center

    .col--lang
      border-right: 1px solid $table-border-color


.page--contest_scoreboard
  .main
    .row
      max-width: 100vw !important;

  .contest-scoreboard-card
    overflow: visible
    border-radius: rem(14px)

  .contest-scoreboard-toolbar
    position: relative
    z-index: 3
    align-items: center
    gap: rem(8px)
    flex-wrap: wrap

  .scoreboard-table-wrap
    position: relative
    overflow-x: auto
    padding-top: rem(8px)

  .scoreboard-table
    table-layout: auto

    thead th
      background: #f8fafc

    tbody tr:first-child td
      border-top: rem(8px) solid #fff

  .data-table td
    line-height: 1.5

  .col--rank
    width: rem(60px)
    text-align: center
    border-right: 1px solid $table-border-color

  .col--user
    min-width: rem(150px)

  .col--solved, .col--time
    width: rem(70px)
    text-align: center

  .col--total_score
    width: rem(100px)
    text-align: center

  .col--problem
    width: rem(100px)
    border-left: 1px solid $table-border-color
    text-align: center

  .scoreboard--acm
    .col--problem
      width: rem(70px) !important

  +mobile()
    .col--user
      width: auto

    .col--problem
      display: none

  .star-highlight
  	background: lighten($primary-color, 90%)

  .contest-timer
    left: auto
    right: rem(16px)
    top: rem(56px)
    pointer-events: none
    border-radius: rem(999px)
    padding: rem(4px 9px)
    background: rgba(#0f172a, .78)
    color: #fff
    box-shadow: 0 rem(8px) rem(22px) rgba(#0f172a, .18)

.page--contest_user
  .col--uid
    width: rem(100px)

.page--contest_balloon
  .col--bid
    width: rem(100px)
  
  .col--status
    width: rem(100px)

  .col--problem
    width: rem(150px)

  .col--awards
    width: rem(130px)

.page--contest_manage
  .col--id
    width: rem(80px)
  .col--score
    width: rem(80px)
