.page--ranking, .page--homepage
  .col--rank
    width: rem(65px)
    position: relative

  .col--user
    width: rem(280px)
    .user-profile-link
      display: inline-flex
      flex-wrap: wrap
      align-items: center
      gap: rem(2px) rem(5px)
      max-width: 100%
      vertical-align: middle
    .user-profile-badge--custom
      display: inline-flex !important
      align-items: center
      max-width: rem(132px)
      overflow: hidden
      text-overflow: ellipsis
      white-space: nowrap
      vertical-align: middle
      box-sizing: border-box

  .col--rp
    width: rem(60px)
    text-align: right

  .col--detail
    width: rem(50px)
    text-align: center
  
  &[lang="en"]
    .col--detail
      width: rem(75px)

  .col--ac
    width: rem(50px)
    text-align: center
  
  &[lang="en"]
    .col--ac
      width: rem(70px)

  .col--bio
    display: block;

  td.col--bio
    height: 36px !important;

  +mobile()
    .col--bio, .col--detail
      display: none
