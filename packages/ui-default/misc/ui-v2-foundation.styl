// UI v2 foundation — presentation tokens + scoped layout polish.
// Keep overrides conservative: prefer variables + light reskin of existing Hydro classes.

:root
  --ui-v2-bg: #f1f5f9
  --ui-v2-surface: #ffffff
  --ui-v2-surface-muted: #f8fafc
  --ui-v2-border: #e2e8f0
  --ui-v2-border-strong: #cbd5e1
  --ui-v2-text: #0f172a
  --ui-v2-text-muted: #64748b
  --ui-v2-accent: #2563eb
  --ui-v2-accent-soft: #eff6ff
  --ui-v2-radius: 14px
  --ui-v2-radius-sm: 10px
  --ui-v2-shadow: 0 12px 40px rgba(15, 23, 42, 0.08)
  --ui-v2-shadow-sm: 0 4px 14px rgba(15, 23, 42, 0.06)

html.page--homepage,
html.page--problem_main,
html.page--problem_detail
  > body > .main
    background: var(--ui-v2-bg)
    padding-top: rem(48px)
    padding-bottom: rem(48px)

// ----- Navigation (sitewide, minimal chrome) -----
html.layout--basic .nav
  background: rgba(255, 255, 255, 0.92)
  backdrop-filter: blur(10px)
  border-bottom: 1px solid var(--ui-v2-border)
  box-shadow: none

// Desktop only: underline active + light hover (mobile slideout unchanged)
+above(rupture.desktop-cutoff)
  html.layout--basic .nav a.nav__item:not(.nav__item--round):not(:has(.nav__logo))
    border-radius: 0
    margin: 0 rem(2px)
    padding: rem(0 12px 2px)
    line-height: rem($nav-item-height - 6)
    border-top: rem(3px) solid transparent
    border-bottom: rem(2px) solid transparent
    color: var(--ui-v2-text)
    transition: color 0.12s ease, background 0.12s ease, box-shadow 0.12s ease, border-color 0.12s ease

    &:hover:not(.nav--active)
      background: rgba(239, 246, 255, 0.55)
      border-top-color: transparent
      color: var(--ui-v2-text)

    &.nav--active
      background: transparent
      border-top-color: transparent
      border-bottom-color: transparent
      color: var(--ui-v2-accent)
      box-shadow: inset 0 rem(-2px) 0 0 var(--ui-v2-accent)

    &.nav--active:before
      box-shadow: none

    &.nav--active:hover
      background: rgba(239, 246, 255, 0.45)
      color: var(--ui-v2-accent)
      box-shadow: inset 0 rem(-2px) 0 0 var(--ui-v2-accent)

  html.layout--basic .nav .nav__item--round
    border-color: var(--ui-v2-accent)
    color: var(--ui-v2-accent)

  html.layout--basic .nav .nav__item--round:hover
    background: var(--ui-v2-accent)
    color: #fff

// ----- Shared: cards, tables, form controls -----
html.page--problem_main,
html.page--problem_detail,
html.page--homepage
  .section
    border: 1px solid var(--ui-v2-border)
    border-radius: var(--ui-v2-radius)
    background: var(--ui-v2-surface)
    box-shadow: var(--ui-v2-shadow-sm)
    overflow: hidden

  .section__header
    background: linear-gradient(180deg, var(--ui-v2-surface-muted) 0%, var(--ui-v2-surface) 100%)
    border-bottom: 1px solid var(--ui-v2-border)

  .section__title
    color: var(--ui-v2-text)
    font-weight: 600

  .data-table
    border-radius: 0
    border: none

  .data-table thead
    background: var(--ui-v2-surface-muted)

  .data-table th,
  .data-table td
    border-color: var(--ui-v2-border)

  .search
    border: 1px solid var(--ui-v2-border)
    border-radius: var(--ui-v2-radius-sm)
    background: var(--ui-v2-surface-muted)
    padding: rem(4px 8px)

  .search input[type="text"]
    border-radius: var(--ui-v2-radius-sm)
    border: 1px solid transparent
    background: var(--ui-v2-surface)

  .search-sort
    border-radius: var(--ui-v2-radius-sm)

  .button.rounded.primary,
  .btn.primary
    background: var(--ui-v2-accent)
    border-color: var(--ui-v2-accent)

  .problem__tag-item
    border-radius: rem(999px)
    border: 1px solid var(--ui-v2-border)
    background: var(--ui-v2-surface-muted)
    color: var(--ui-v2-text-muted)

// ----- Homepage -----
.page--homepage .ui-v2-home
  max-width: rem(1200px)
  margin: 0 auto
  padding: 0 rem(12px)

.page--homepage .ui-v2-home__hero
  border-radius: var(--ui-v2-radius)
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 18%, #eff6ff 45%, #e0f2fe 78%, #dbeafe 100%)
  border: 1px solid rgba(148, 163, 184, 0.35)
  color: var(--ui-v2-text)
  padding: rem(28px 28px 32px)
  margin-bottom: rem(22px)
  box-shadow: var(--ui-v2-shadow-sm)
  min-height: rem(280px)
  display: flex
  align-items: stretch

.page--homepage .ui-v2-home__hero-inner
  display: grid
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr)
  gap: rem(28px 32px)
  align-items: center
  width: 100%

  +below(rupture.desktop-cutoff)
    grid-template-columns: 1fr
    gap: rem(20px)

.page--homepage .ui-v2-home__hero-text
  min-width: 0

.page--homepage .ui-v2-home__hero-actions
  display: flex
  flex-wrap: wrap
  gap: rem(10px)
  margin-top: rem(22px)

.page--homepage .ui-v2-home__hero-actions .button.rounded
  border: 1px solid var(--ui-v2-border-strong)
  background: #fff
  color: var(--ui-v2-text)
  backdrop-filter: none

.page--homepage .ui-v2-home__hero-actions .button.rounded:hover
  background: var(--ui-v2-surface-muted)
  border-color: var(--ui-v2-accent)

.page--homepage .ui-v2-home__hero-actions .button.rounded.primary
  background: var(--ui-v2-accent)
  color: #fff
  border-color: var(--ui-v2-accent)

.page--homepage .ui-v2-home__hero-actions .button.rounded.primary:hover
  background: #1d4ed8
  border-color: #1d4ed8
  color: #fff

.page--homepage .ui-v2-home__hero-visual
  display: flex
  align-items: center
  justify-content: center
  min-height: rem(220px)

  +below(rupture.desktop-cutoff)
    min-height: rem(180px)

.page--homepage .ui-v2-home__hero-panel
  position: relative
  width: 100%
  max-width: rem(300px)
  aspect-ratio: 1.12
  border-radius: var(--ui-v2-radius-sm)
  background: linear-gradient(165deg, rgba(255, 255, 255, 0.75) 0%, rgba(239, 246, 255, 0.55) 55%, rgba(224, 242, 254, 0.4) 100%)
  border: 1px solid rgba(148, 163, 184, 0.28)
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9), 0 rem(10px) rem(28px) rgba(15, 23, 42, 0.06)
  overflow: hidden
  opacity: 0.92

.page--homepage .ui-v2-home__hero-code
  position: absolute
  left: 50%
  top: 50%
  transform: translate(-50%, -52%)
  font-size: rem(44px)
  font-weight: 700
  font-family: var(--code-font-family, ui-monospace, monospace)
  letter-spacing: rem(-2px)
  color: rgba(37, 99, 235, 0.16)
  text-shadow: none

.page--homepage .ui-v2-home__hero-dot
  position: absolute
  border-radius: rem(8px)
  background: rgba(37, 99, 235, 0.08)
  border: 1px solid rgba(37, 99, 235, 0.1)
  box-shadow: none
  opacity: 0.65

.page--homepage .ui-v2-home__hero-dot--1
  width: rem(44px)
  height: rem(44px)
  left: 12%
  top: 18%
  animation: ui-v2-float 5s ease-in-out infinite

.page--homepage .ui-v2-home__hero-dot--2
  width: rem(28px)
  height: rem(28px)
  right: 14%
  top: 26%
  animation: ui-v2-float 6s ease-in-out 0.5s infinite

.page--homepage .ui-v2-home__hero-dot--3
  width: rem(36px)
  height: rem(36px)
  right: 18%
  bottom: 16%
  animation: ui-v2-float 5.5s ease-in-out 1s infinite

@keyframes ui-v2-float
  0%, 100%
    transform: translateY(0)
  50%
    transform: translateY(rem(-8px))

.page--homepage .ui-v2-home__eyebrow
  margin: 0 0 rem(8px)
  font-size: rem(12px)
  letter-spacing: 0.12em
  text-transform: uppercase
  color: #64748b
  opacity: 1

.page--homepage .ui-v2-home__title
  margin: 0 0 rem(12px)
  font-size: clamp(rem(28px), 4vw, rem(40px))
  line-height: 1.16
  font-weight: 800
  max-width: rem(560px)
  color: #0c1429
  letter-spacing: rem(-0.5px)

.page--homepage .ui-v2-home__subtitle
  margin: 0
  font-size: rem(17px)
  line-height: 1.6
  color: #475569
  max-width: rem(520px)
  opacity: 1

.page--homepage .ui-v2-home__quick
  display: grid
  grid-template-columns: repeat(4, minmax(0, 1fr))
  gap: rem(14px)
  margin-bottom: rem(24px)

  +below(rupture.desktop-cutoff)
    grid-template-columns: repeat(2, minmax(0, 1fr))

.page--homepage .ui-v2-home__card
  display: block
  padding: rem(16px 16px 18px)
  border-radius: var(--ui-v2-radius-sm)
  background: linear-gradient(180deg, var(--ui-v2-surface) 0%, var(--ui-v2-surface-muted) 100%)
  border: 1px solid var(--ui-v2-border)
  box-shadow: var(--ui-v2-shadow-sm)
  text-decoration: none
  color: var(--ui-v2-text)
  transition: box-shadow 0.12s ease, border-color 0.12s ease
  position: relative
  overflow: hidden

.page--homepage .ui-v2-home__card::before
  content: ''
  position: absolute
  left: 0
  top: 0
  width: 100%
  height: rem(3px)
  background: linear-gradient(90deg, var(--ui-v2-accent), #38bdf8)
  opacity: 0.85

.page--homepage .ui-v2-home__card:hover
  box-shadow: 0 rem(8px) rem(24px) rgba(15, 23, 42, 0.07)
  border-color: rgba(37, 99, 235, 0.22)

.page--homepage .ui-v2-home__card-icon
  display: block
  font-size: rem(22px)
  line-height: 1
  margin-bottom: rem(8px)

.page--homepage .ui-v2-home__card-label
  display: block
  font-size: rem(11px)
  font-weight: 600
  letter-spacing: 0.06em
  text-transform: uppercase
  color: var(--ui-v2-text-muted)
  margin-bottom: rem(2px)

.page--homepage .ui-v2-home__card-title
  display: block
  font-size: rem(17px)
  font-weight: 700
  margin-bottom: rem(6px)

.page--homepage .ui-v2-home__card-desc
  display: block
  font-size: rem(12px)
  line-height: 1.45
  color: var(--ui-v2-text-muted)

.page--homepage .ui-v2-home__body .row
  margin-left: rem(-6px)
  margin-right: rem(-6px)

.page--homepage .ui-v2-home__body .columns
  padding-left: rem(6px)
  padding-right: rem(6px)

// ----- Homepage lower panels (learning layout) -----
.page--homepage .ui-v2-home__panels
  align-items: flex-start

.page--homepage .ui-v2-home__col--main,
.page--homepage .ui-v2-home__col--side
  display: flex
  flex-direction: column
  gap: rem(16px)

.page--homepage .ui-v2-home__body .section
  margin-bottom: 0

.page--homepage .ui-v2-home__body .section__header
  padding: rem(14px 18px 12px)

.page--homepage .ui-v2-home__body .section__title
  font-size: rem(17px)
  font-weight: 700
  letter-spacing: rem(-0.2px)

.page--homepage .ui-v2-home__body .section:hover
  box-shadow: var(--ui-v2-shadow)

.page--homepage .ui-v2-home-panel--bulletin .section__header
  border-bottom: 1px solid var(--ui-v2-border)
  background: linear-gradient(180deg, #fff 0%, var(--ui-v2-surface-muted) 100%)

.page--homepage .ui-v2-home-panel__lead
  margin: 0
  padding: rem(12px 18px 0)
  font-size: rem(14px)
  line-height: 1.55
  color: var(--ui-v2-text-muted)

.page--homepage .ui-v2-home-bulletin-source
  margin: 0 rem(14px) rem(14px)
  padding: rem(12px 14px)
  max-height: rem(220px)
  overflow-y: auto
  font-size: rem(13px)
  line-height: 1.55
  color: #64748b
  background: var(--ui-v2-surface-muted)
  border: 1px solid var(--ui-v2-border)
  border-radius: var(--ui-v2-radius-sm)

.page--homepage .ui-v2-home-bulletin-source h1,
.page--homepage .ui-v2-home-bulletin-source h2,
.page--homepage .ui-v2-home-bulletin-source h3
  font-size: rem(14px) !important
  margin: rem(8px) 0 rem(4px) !important
  color: #64748b !important
  font-weight: 600 !important

.page--homepage .ui-v2-home-bulletin-source p,
.page--homepage .ui-v2-home-bulletin-source li
  font-size: rem(13px)
  color: #64748b

.page--homepage .ui-v2-home__col--side .section.side
  margin-bottom: 0

.page--homepage .ui-v2-home__col--side .section__body
  padding: rem(12px 16px 16px)

.page--homepage .ui-v2-home__col--main .page--training_main,
.page--homepage .ui-v2-home__col--main .page--contest_main,
.page--homepage .ui-v2-home__col--main .page--homework_main,
.page--homepage .ui-v2-home__col--main .page--discussion_main
  transition: box-shadow 0.12s ease, border-color 0.12s ease

.page--homepage .ui-v2-home__col--main .page--training_main:hover,
.page--homepage .ui-v2-home__col--main .page--contest_main:hover,
.page--homepage .ui-v2-home__col--main .page--homework_main:hover,
.page--homepage .ui-v2-home__col--main .page--discussion_main:hover
  border-color: rgba(37, 99, 235, 0.2)

  +mobile()
    &:hover
      border-color: var(--ui-v2-border)

// ----- Problem list (/p) -----
// Compact page head: only main column, no hero-style strip
.page--problem_main .ui-v2-problem-main .medium-9 > .ui-v2-page-head
  margin: 0 0 rem(16px)
  padding: rem(18px 22px 20px)
  border-radius: var(--ui-v2-radius-sm)
  border: 1px solid var(--ui-v2-border)
  background: var(--ui-v2-surface)
  box-shadow: var(--ui-v2-shadow-sm)
  text-align: left

.page--problem_main .ui-v2-problem-main .medium-9 > .ui-v2-page-head__title
  margin: 0 0 rem(4px)
  font-size: rem(22px)
  font-weight: 700
  color: var(--ui-v2-text)
  letter-spacing: rem(-0.2px)

.page--problem_main .ui-v2-problem-main .medium-9 > .ui-v2-page-head__subtitle
  margin: 0
  max-width: rem(560px)
  font-size: rem(14px)
  line-height: 1.5
  color: var(--ui-v2-text-muted)

.page--problem_main .ui-v2-problem-main .section.display-mode
  overflow: visible

.page--problem_main .ui-v2-problem-main .section.display-mode > .section__body.no-padding:first-of-type
  padding: rem(16px 18px 18px) !important
  border-bottom: 1px solid var(--ui-v2-border)
  background: linear-gradient(180deg, var(--ui-v2-surface-muted) 0%, var(--ui-v2-surface) 100%)

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar
  border-radius: var(--ui-v2-radius-sm)
  border: 1px solid var(--ui-v2-border)
  background: var(--ui-v2-surface)
  padding: rem(6px 8px)
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9)

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search
  border: none
  border-radius: var(--ui-v2-radius-sm)
  background: var(--ui-v2-surface-muted)
  padding: rem(4px 6px)
  min-height: rem(44px)
  align-items: center

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search > input[type="text"]
  height: rem(36px)
  padding: rem(0 12px)
  font-size: rem(14px)

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search > button
  height: rem(36px)
  width: rem(40px)
  border: 1px solid var(--ui-v2-accent)
  background: var(--ui-v2-accent)
  color: #fff
  border-radius: 0 var(--ui-v2-radius-sm) var(--ui-v2-radius-sm) 0

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search > button:hover
  background: #1d4ed8
  border-color: #1d4ed8

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search-sort
  position: absolute
  top: 50%
  transform: translateY(-50%)
  right: rem(40px)
  height: rem(34px)
  border: 1px solid var(--ui-v2-border)
  border-radius: var(--ui-v2-radius-sm)
  background: var(--ui-v2-surface)
  padding: 0 rem(8px)
  font-size: rem(13px)
  color: var(--ui-v2-text)

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search > .ui-v2-problem-stat
  position: absolute
  top: 50%
  transform: translateY(-50%)
  right: rem(168px)
  font-size: rem(13px)
  color: var(--ui-v2-text-muted)

.page--problem_main .ui-v2-problem-main .ui-v2-problem-toolbar .search > .ui-v2-problem-stat p
  margin: 0
  line-height: 1.35
  white-space: nowrap

.page--problem_main .ui-v2-problem-main .section.display-mode > .section__body.no-padding:last-of-type
  padding: rem(8px 0 0) !important
  background: var(--ui-v2-surface)

.page--problem_main .ui-v2-problem-main .section__table-container
  position: relative
  z-index: 1

.page--problem_main .ui-v2-problem-main .section__table-header
  z-index: 100
  overflow: visible

.page--problem_main .ui-v2-problem-main .section__table-header th::before,
.page--problem_main .ui-v2-problem-main .section__table-header th::after,
.page--problem_main .ui-v2-problem-main .section__table-header thead::before,
.page--problem_main .ui-v2-problem-main .section__table-header thead::after
  pointer-events: none

.page--problem_main .ui-v2-problem-main .data-table thead th
  font-size: rem(12px)
  font-weight: 600
  color: var(--ui-v2-text-muted)
  letter-spacing: rem(0.02em)
  padding: rem(14px 12px)
  border-bottom: 1px solid var(--ui-v2-border)
  background: var(--ui-v2-surface-muted)

.page--problem_main .ui-v2-problem-main .data-table thead
  background: var(--ui-v2-surface-muted)

// th 不要用 flex（会破坏 table 列宽/命中区）；float 控件须在 DOM 中先于块级标题
.page--problem_main .ui-v2-problem-main th.col--name
  overflow: visible
  position: relative
  z-index: 5
  vertical-align: middle

.page--problem_main .ui-v2-problem-main .data-table tbody td
  padding: rem(13px 12px)
  vertical-align: middle
  font-size: rem(14px)

.page--problem_main .ui-v2-problem-main .data-table tbody tr
  transition: background 0.12s ease, box-shadow 0.12s ease

.page--problem_main .ui-v2-problem-main .data-table tbody tr:hover
  background: #f1f5f9
  box-shadow: inset rem(3px) 0 0 0 rgba(37, 99, 235, 0.35)

.page--problem_main .ui-v2-problem-main .col--pid
  font-variant-numeric: tabular-nums
  font-weight: 600
  font-size: rem(13px)
  color: var(--ui-v2-text-muted)

.page--problem_main .ui-v2-problem-main .col--problem-name,
.page--problem_main .ui-v2-problem-main td.col--name
  font-weight: 500
  color: var(--ui-v2-text)

.page--problem_main .ui-v2-problem-main .col--problem-name a,
.page--problem_main .ui-v2-problem-main td.col--name a
  color: var(--ui-v2-text)
  text-decoration: none

.page--problem_main .ui-v2-problem-main .col--problem-name a:hover,
.page--problem_main .ui-v2-problem-main td.col--name a:hover
  color: var(--ui-v2-accent)

.page--problem_main .ui-v2-problem-main .problem__tag-item
  font-size: rem(11px)
  padding: rem(2px 8px)
  border-color: var(--ui-v2-border)
  background: #fff
  color: var(--ui-v2-text-muted)

.page--problem_main .ui-v2-problem-main .col--ac-tried
  font-variant-numeric: tabular-nums
  font-size: rem(13px)
  color: var(--ui-v2-text-muted)

.page--problem_main .ui-v2-problem-main .col--difficulty
  font-size: rem(13px)
  font-weight: 600
  color: var(--ui-v2-text)

// 原生为 span.toggle-tag；勿用 a(href)，以免与全局链接/pjax 行为冲突
.page--problem_main .ui-v2-problem-main .toggle-tag
  position: relative
  z-index: 7
  pointer-events: auto
  cursor: pointer

.page--problem_main .ui-v2-problem-main .medium-3 .section.side
  border-radius: var(--ui-v2-radius-sm)
  margin-bottom: rem(14px)
  box-shadow: var(--ui-v2-shadow-sm)

.page--problem_main .ui-v2-problem-main .medium-3 .section.side:last-child
  margin-bottom: 0

.page--problem_main .ui-v2-problem-main .medium-3 .section.side .section__header
  padding: rem(12px 16px 10px)

.page--problem_main .ui-v2-problem-main .medium-3 .section.side .section__title
  font-size: rem(15px)
  font-weight: 700
  letter-spacing: rem(-0.2px)

.page--problem_main .ui-v2-problem-main .medium-3 .section__body
  padding: rem(12px 14px 16px)

.page--problem_main .ui-v2-problem-main .medium-3 .group-list__item
  margin-bottom: rem(16px)
  padding-bottom: rem(14px)
  border-bottom: 1px solid var(--ui-v2-border)

.page--problem_main .ui-v2-problem-main .medium-3 .group-list__item:last-child
  margin-bottom: 0
  padding-bottom: 0
  border-bottom: none

.page--problem_main .ui-v2-problem-main .medium-3 .group-list__item .section__title
  margin: 0 0 rem(8px)
  font-size: rem(14px)

.page--problem_main .ui-v2-problem-main .medium-3 .group-list__item .section__title a
  color: var(--ui-v2-text)
  text-decoration: none

