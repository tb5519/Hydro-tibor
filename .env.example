# 复制为 .env 后由 Docker Compose 读取并注入容器（与代码目录分离的卷存数据）。
# cp .env.example .env

# 宿主机访问 Hydro 的端口（容器内默认监听 8888，见系统设置 server.port）
HYDRO_HTTP_PORT=8888

# MongoDB 连接串（compose 中网内服务名为 mongo）
HYDRO_MONGODB_URL=mongodb://mongo:27017/hydro

# 启用的插件列表（JSON 数组字符串）。示例：再加评测机 UI
# HYDRO_ADDONS_JSON=["@hydrooj/ui-default","@hydrooj/hydrojudge"]

# 以下为可选调试开关
# HYDRO_SKIP_YARN_INSTALL=1
# HYDRO_HOME=/data/hydro
# HYDRO_YARN_VERSION=4.9.1
# YARN_ENABLE_INLINE_BUILDS=1
